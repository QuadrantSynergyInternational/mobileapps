# Copy this file to scripts/.env and fill in the values.
# .env is loaded automatically by repack_android.sh and repack_ios.sh in local mode.
# Never commit .env to version control.

# ── Self-hosted source repo ──────────────────────────────────────────────────
REPO=git.example.com/org/your-app.git
REPO_BRANCH=main
GIT_USERNAME=your_git_username
GIT_PASSWORD=your_git_password_or_token

# ── GitHub (release download + provision repo) ───────────────────────────────
GH_TOKEN=ghp_your_github_token
RELEASE_REPO=org/release-repo
RELEASE_TAG=v1.0.0-Release-main

# ── Android-specific ─────────────────────────────────────────────────────────
APK_FILENAME=app-release.apk
KEYSTORE_PATH=android/app/release.keystore
KEYSTORE_PASSWORD=your_keystore_password
KEY_ALIAS=your_key_alias
KEY_PASSWORD=your_key_password

# ── iOS-specific ─────────────────────────────────────────────────────────────
IPA_FILENAME=output-Release.ipa
PROJECT_ID=your-project-id
PROVISION_FILE=master-uat
P12_PASSWORD=your_p12_password
PROVISION_REPO_TOKEN=ghp_your_provision_repo_token
